<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. If the request is for an actual file in public/, serve it
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 2. Otherwise, send everything to the public index.php
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>
