<?php

class signup extends controller
{
    public function index(): void
    {
        die('INDEX METHOD');
        $model = $this->model('signup_model');

        $data = [
            'regions' => $model->get_regions()
        ];

        $this->view('public/signup/signup', $data);
    }

    public function submit(): void
    {
        if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
            header('Location: ' . URLROOT . '/signup');
            exit;
        }

        $model = $this->model('signup_model');

        $birth_date = trim($_POST['birth_date'] ?? '');
        $zip        = trim($_POST['zip'] ?? '');

        $yyyy = (int)substr($birth_date, 0, 4);
        $mm   = (int)substr($birth_date, 5, 2);
        $dd   = (int)substr($birth_date, 8, 2);

        $data = [
            'legal_name_encrypted' => trim($_POST['legal_name'] ?? ''),
            'chosen_name'          => trim($_POST['chosen_name'] ?? ''),
            'initials_display'     => trim($_POST['initials_display'] ?? ''),
            'sex'                  => trim($_POST['sex'] ?? ''),
            'contact_text'         => trim($_POST['contact_text'] ?? ''),

            'region_id'    => (int)($_POST['region_id'] ?? 0),
            'state_id'     => (int)($_POST['state_id'] ?? 0),
            'county_id'    => (int)($_POST['county_id'] ?? 0),

            'municipality' => trim($_POST['municipality'] ?? ''),
            'address'      => trim($_POST['address'] ?? ''),
            'zip'          => $zip,

            'birth_date'   => $birth_date,
            'birth_number' => $this->birth_number_from_date($yyyy, $mm, $dd),
            'zodiac_name'  => $this->get_zodiac($mm, $dd),

            'lat'        => null,
            'lon'        => null,
            'mgrs_coord' => null
        ];

        $member_id = $model->register_final_member($data);

        if ($member_id) {
            header('Location: ' . URLROOT . '/signup/success');
            exit;
        }

        die('Insert failed.');
    }

    private function birth_number_from_date(int $yyyy, int $mm, int $dd): int
    {
        $digits = str_split(sprintf('%02d%02d%04d', $mm, $dd, $yyyy));
        $sum = array_sum($digits);

        while ($sum > 9) {
            $sum = array_sum(str_split((string)$sum));
        }

        return $sum;
    }

    private function get_zodiac(int $month, int $day): string
    {
        $signs = [
            ['capricorn', 19],
            ['aquarius', 18],
            ['pisces', 20],
            ['aries', 19],
            ['taurus', 20],
            ['gemini', 20],
            ['cancer', 22],
            ['leo', 22],
            ['virgo', 22],
            ['libra', 22],
            ['scorpio', 21],
            ['sagittarius', 21],
            ['capricorn', 31]
        ];

        return ($day <= $signs[$month - 1][1])
            ? $signs[$month - 1][0]
            : $signs[$month][0];
    }

    public function get_states($params): void
    {
        $rid = $params[2] ?? 0;

        header('Content-Type: application/json');
        echo json_encode(
            $this->model('signup_model')->get_states_by_region((int)$rid)
        );
        exit;
    }

    public function get_counties($params): void
    {
        $sid = $params[2] ?? 0;

        header('Content-Type: application/json');
        echo json_encode(
            $this->model('signup_model')->get_counties_by_state((int)$sid)
        );
        exit;
    }
}
